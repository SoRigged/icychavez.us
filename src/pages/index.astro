---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { services } from "../data/services";
---

<Layout title="Icy Navigator">
  <header class="pt-12 pb-8 text-center">
    <h1 class="text-3xl font-bold tracking-tight text-zinc-100">Icy Navigator</h1>
    <a href="/status" class="mt-2 inline-block text-sm text-zinc-500 hover:text-zinc-300 transition-colors">
      Service Status
    </a>
  </header>

  <main class="flex-1 mx-auto w-full max-w-3xl px-4 pb-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {services.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>
  </main>

  <footer class="py-6 text-center text-sm text-zinc-600">
    Chavez
  </footer>
</Layout>
